{
  "name": "in-square/opendxp-seo-bundle",
  "description": "Seo bundle for OpenDXP",
  "type": "opendxp-bundle",
  "keywords": ["opendxp", "seo", "opendxp-bundle", "opendxp-plugin"],
  "homepage": "https://github.com/in-square/opendxp-seo-bundle",
  "license": "GPL-3.0-or-later",
  "authors": [
    {
      "name": "Władysław Dudko",
      "email": "wladyslaw.dudko@gmail.com"
    }
  ],
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/in-square/seo-bundle"
    }
  ],
  "require": {
    "open-dxp/opendxp": "^1.0",
    "in-square/seo-bundle": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "InSquare\\OpendxpSeoBundle\\": "src/"
    }
  },
  "extra": {
    "opendxp": {
      "bundles": [
        "InSquare\\OpendxpSeoBundle\\InSquareOpendxpSeoBundle"
      ]
    }
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.11",
    "phpstan/phpstan": "^1.8",
    "phpstan/phpstan-symfony": "^1.2"
  },
  "scripts": {
    "fix": [
      "vendor/bin/php-cs-fixer fix --config=.php-cs --using-cache=no --diff --allow-risky=yes",
      "vendor/bin/phpstan analyse -c phpstan.neon"
    ]
  }
}
